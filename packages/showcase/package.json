{
  "name": "@gfld/showcase",
  "version": "1.0.0-rc1",
  "type": "module",
  "private": true,
  "description": "Single-origin static showcase: in-browser Wayland compositor + WASM sample apps, picked via buttons.",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve:static": "vite build && python3 -m http.server 8090 --bind 127.0.0.1 --directory dist",
    "e2e": "node e2e/pw-showcase.js"
  },
  "dependencies": {
    "@gfld/client-protocol": "workspace:^",
    "@gfld/common": "workspace:^",
    "@gfld/compositor": "workspace:^",
    "gl-matrix": "^3.4.3"
  },
  "devDependencies": {
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vite-plugin-glsl": "^1.3.0"
  }
}
